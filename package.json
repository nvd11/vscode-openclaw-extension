{
  "name": "vscode-openclaw-extension",
  "displayName": "OpenClaw Remote Assistant",
  "description": "Talk to Alice (OpenClaw) from your VSCode sidebar",
  "version": "0.0.4",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:openclaw-sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openclaw-sidebar-view",
          "title": "OpenClaw",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "openclaw-sidebar-view": [
        {
          "type": "webview",
          "id": "openclaw-sidebar",
          "name": "Alice Assistant",
          "icon": "media/icon.svg",
          "contextualTitle": "Alice Assistant"
        }
      ]
    },
    "commands": [
      {
        "command": "openclaw.helloWorld",
        "title": "OpenClaw: Hello World"
      }
    ],
    "configuration": {
      "title": "OpenClaw Assistant",
      "properties": {
        "openclaw.bridgeUrl": {
          "type": "string",
          "default": "http://localhost:3000/api/chat",
          "description": "URL of the OpenClaw backend bridge (e.g., http://YOUR_GCP_IP:3000/api/chat)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}